{
  "name": "@pane-craft/react",
  "version": "0.2.0",
  "description": "A component library for creating editor-style functionality, including tabs, split panes, and drag and drop functionality.",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./components/*": {
      "import": {
        "types": "./dist/components/*/index.d.ts",
        "default": "./dist/components/*/index.js"
      },
      "require": {
        "types": "./dist/components/*/index.d.cts",
        "default": "./dist/components/*/index.cjs"
      }
    },
    "./styles/*.css": "./dist/styles/*.css",
    "./package.json": "./package.json"
  },
  "module": "./dist/index.js",
  "main": "./dist/index.cjs",
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && node scripts/finalize-dts.mjs && node scripts/finalize-css.mjs",
    "build:watch": "vite build --watch",
    "dev": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "prepublishOnly": "pnpm build && pnpm exec publint && pnpm exec attw --pack",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "keywords": [
    "react",
    "typescript",
    "tabs",
    "split-pane",
    "splitter",
    "resizable",
    "drag-and-drop",
    "pane",
    "editor",
    "ide",
    "layout",
    "docking"
  ],
  "author": "Peter Justeson (https://github.com/JusticeSquad)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pane-craft/pane-craft.git"
  },
  "bugs": {
    "url": "https://github.com/pane-craft/pane-craft/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.14.0",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "latest",
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/js": "^9.21.0",
    "@microsoft/api-extractor": "^7.58.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "4.1.0",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-tsdoc": "^0.5.2",
    "happy-dom": "^20.8.9",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "postcss-preset-env": "^11.2.0",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup-plugin-preserve-directives": "^0.4.0",
    "storybook": "^10.3.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vitest": "^4.1.0"
  },
  "browserslist": [
    "chrome >= 64",
    "firefox >= 67",
    "safari >= 12",
    "edge >= 79"
  ]
}
